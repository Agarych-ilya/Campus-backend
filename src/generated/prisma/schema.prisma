datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js" // <--- Изменили на prisma-client
  output   = "../src/generated/prisma" // <--- Указали папку внутри твоего проекта
}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  email     String   @unique
  password  String   @map("password_hash")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
